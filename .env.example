# =========================
# App
# =========================
APP_NAME=AIKnowledgeBase
DEBUG=true
API_V1_STR=/api/v1
CORS_ORIGINS=["*"]

# =========================
# Security
# =========================
SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
TEMP_TOKEN_EXPIRE_MINUTES=5

# =========================
# Database (PostgreSQL default)
# =========================
DB_DIALECT=postgresql
SQLITE_PATH=./data/app.db

# postgresql
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_NAME=knowledge_base

# PostgreSQL + Apache AGE
GRAPH_BACKEND=postgres_relational
POSTGRES_AGE_ENABLED=false
POSTGRES_AGE_GRAPH_NAME=knowledge_graph
POSTGRES_AGE_TAG=PG16/v1.6.0-rc0

# =========================
# Redis
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# =========================
# Captcha / Email Code
# =========================
CAPTCHA_LENGTH=4
CAPTCHA_EXPIRE_SECONDS=300
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRE_SECONDS=300

# =========================
# Rate Limits
# =========================
RATE_LIMIT_CAPTCHA_LIMIT=10
RATE_LIMIT_CAPTCHA_WINDOW=60
RATE_LIMIT_EMAIL_CODE_LIMIT=3
RATE_LIMIT_EMAIL_CODE_WINDOW=60
RATE_LIMIT_REGISTER_LIMIT=5
RATE_LIMIT_REGISTER_WINDOW=3600

# =========================
# SMTP
# =========================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=AI KB

# =========================
# MinIO
# =========================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_SECURE=false
MINIO_DEFAULT_BUCKET=default

# =========================
# Elasticsearch
# =========================
ES_HOST=http://elasticsearch:9200
ES_USER=
ES_PASSWORD=CHANGE_ME_ES_PASSWORD
ES_VERIFY_CERTS=false
ES_DEFAULT_INDEX=default

# =========================
# Kafka
# =========================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_DEFAULT_TOPIC=default

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_CHAT_MAX_TOKENS=2000
OPENAI_VISION_ENABLED=true
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_VISION_MAX_TOKENS=1200
OPENAI_VISION_MAX_IMAGES_PER_FILE=10

# =========================
# Gemini / Vertex Visual Embeddings
# =========================
GEMINI_VISUAL_EMBEDDING_ENABLED=false
GEMINI_VISUAL_EMBEDDING_BACKEND=auto
# Backend selection:
#   auto      -> try AI Studio first, then fallback to Vertex if configured
#   ai_studio -> use GEMINI_API_KEY only
#   vertex    -> use Vertex project + ADC credentials
#
# AI Studio example:
#   GEMINI_VISUAL_EMBEDDING_BACKEND=ai_studio
#   GEMINI_VISUAL_EMBEDDING_MODEL=gemini-embedding-2-preview
#   GEMINI_VISUAL_EMBEDDING_DIMENSIONS=3072
#   GEMINI_API_KEY=YOUR_AI_STUDIO_API_KEY
#
# Vertex example:
#   GEMINI_VISUAL_EMBEDDING_BACKEND=vertex
#   GEMINI_VISUAL_EMBEDDING_MODEL=multimodalembedding@001
#   GEMINI_VISUAL_EMBEDDING_DIMENSIONS=1408
#   GEMINI_VISUAL_EMBEDDING_PROJECT_ID=your-gcp-project-id
#   GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-vertex.json
GEMINI_VISUAL_EMBEDDING_MODEL=multimodalembedding@001
GEMINI_VISUAL_EMBEDDING_DIMENSIONS=1408
GEMINI_VISUAL_EMBEDDING_PROJECT_ID=
GEMINI_VISUAL_EMBEDDING_LOCATION=us-central1
GEMINI_VISUAL_EMBEDDING_TIMEOUT_SEC=60
GEMINI_VISUAL_EMBEDDING_CONTEXTUAL_TEXT_ENABLED=false
# Vertex AI auth uses ADC inside the app container (for example GOOGLE_APPLICATION_CREDENTIALS).
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-vertex.json
GEMINI_API_KEY=

# =========================
# Conversation / WebSocket / Search / Logging
# =========================
CONVERSATION_MAX_MESSAGES=20
CONVERSATION_TTL_DAYS=7
CHAT_STOP_TOKEN_TTL=300

WEBSOCKET_MAX_CONNECTIONS_PER_USER=10
WEBSOCKET_MAX_CONNECTIONS_PER_INSTANCE=1000
WEBSOCKET_IDLE_TIMEOUT=3600
WEBSOCKET_CLEANUP_INTERVAL=300

SEARCH_VECTOR_WEIGHT=0.7
SEARCH_TEXT_WEIGHT=0.3

DEBUG_LOG_LEVEL=DEBUG
PRODUCTION_LOG_LEVEL=INFO
