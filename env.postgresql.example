# =========================
# App
# =========================
APP_NAME=AIKnowledgeBase
DEBUG=false
API_V1_STR=/api/v1
CORS_ORIGINS=["https://your-domain.com"]

# =========================
# Security
# =========================
SECRET_KEY=change_me_to_a_secure_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
TEMP_TOKEN_EXPIRE_MINUTES=5

# =========================
# Database (PostgreSQL for production)
# =========================
DB_DIALECT=postgresql
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=knowledge_base

# 可选：直接覆盖连接串（优先级最高）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/knowledge_base

# 以下字段在 postgresql 模式下不会使用，保留是为了兼容统一配置
SQLITE_PATH=./data/app.db

# =========================
# Redis
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me

# =========================
# Captcha / Email Code
# =========================
CAPTCHA_LENGTH=4
CAPTCHA_EXPIRE_SECONDS=300
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRE_SECONDS=300

# =========================
# Rate Limits
# =========================
RATE_LIMIT_CAPTCHA_LIMIT=10
RATE_LIMIT_CAPTCHA_WINDOW=60
RATE_LIMIT_EMAIL_CODE_LIMIT=3
RATE_LIMIT_EMAIL_CODE_WINDOW=60
RATE_LIMIT_REGISTER_LIMIT=5
RATE_LIMIT_REGISTER_WINDOW=3600

# =========================
# SMTP
# =========================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=AI KB

# =========================
# MinIO
# =========================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_DEFAULT_BUCKET=default

# =========================
# Elasticsearch
# =========================
ES_HOST=http://elasticsearch:9200
ES_USER=
ES_PASSWORD=
ES_VERIFY_CERTS=false
ES_DEFAULT_INDEX=default

# =========================
# Kafka
# =========================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_DEFAULT_TOPIC=default

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=sk-xxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.3
OPENAI_CHAT_MAX_TOKENS=2000

# =========================
# Conversation / WebSocket / Search / Logging
# =========================
CONVERSATION_MAX_MESSAGES=20
CONVERSATION_TTL_DAYS=7
CHAT_STOP_TOKEN_TTL=300

WEBSOCKET_MAX_CONNECTIONS_PER_USER=10
WEBSOCKET_MAX_CONNECTIONS_PER_INSTANCE=1000
WEBSOCKET_IDLE_TIMEOUT=3600
WEBSOCKET_CLEANUP_INTERVAL=300

SEARCH_VECTOR_WEIGHT=0.7
SEARCH_TEXT_WEIGHT=0.3

DEBUG_LOG_LEVEL=INFO
PRODUCTION_LOG_LEVEL=INFO
